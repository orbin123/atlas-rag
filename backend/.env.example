ATLAS_ENV=development
ATLAS_API_HOST=127.0.0.1
ATLAS_API_PORT=8000
ATLAS_CORS_ORIGINS=http://localhost:3000
ATLAS_DATABASE_URL=sqlite:///./storage/atlas.db
ATLAS_STORAGE_ROOT=./storage
ATLAS_LOG_LEVEL=INFO
ATLAS_MAX_UPLOAD_MB=50

ATLAS_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
ATLAS_EMBEDDING_REVISION=1110a243fdf4706b3f48f1d95db1a4f5529b4d41
ATLAS_EMBEDDING_DIMENSION=384
ATLAS_EMBEDDING_MAX_INPUT_TOKENS=256
ATLAS_EMBEDDING_NORMALIZE=true
ATLAS_EMBEDDING_BATCH_SIZE=32

ATLAS_CHUNKING_VERSION=atlas-page-sentence-v1
ATLAS_CHUNK_TARGET_TOKENS=220
ATLAS_CHUNK_MAX_TOKENS=240
ATLAS_CHUNK_OVERLAP_TOKENS=60

ATLAS_DEFAULT_TOP_K=5
ATLAS_MAX_TOP_K=20
ATLAS_MINIMUM_CONTEXT_SCORE=0.46
ATLAS_DUPLICATE_SIMILARITY_THRESHOLD=0.97
ATLAS_WORKER_POLL_INTERVAL_SECONDS=0.25
ATLAS_WORKER_STALE_SECONDS=120
ATLAS_SNAPSHOT_RETENTION_COUNT=2

ATLAS_GENERATION_ENABLED=false
ATLAS_GENERATION_MODEL=
ATLAS_GENERATION_BASE_URL=https://api.openai.com/v1
ATLAS_GENERATION_API_KEY=
ATLAS_GENERATION_TIMEOUT_SECONDS=30
ATLAS_GENERATION_MAX_CONCURRENCY=2
ATLAS_GENERATION_MAX_OUTPUT_TOKENS=512
ATLAS_GENERATION_CONTEXT_MAX_TOKENS=3000
ATLAS_EVALUATION_GENERATION_MAX_QUESTIONS=10
