{
  "contractVersion": "1.0.0",
  "basePath": "/api/v1",
  "jsonNaming": "camelCase",
  "datetimeFormat": "UTC ISO 8601 with Z",
  "pagination": {
    "defaultPage": 1,
    "defaultPageSize": 25,
    "maximumPageSize": 100,
    "requiredFields": ["items", "page", "pageSize", "total", "totalPages"]
  },
  "retrieval": {
    "defaultTopK": 5,
    "maximumTopK": 20,
    "minimumContextScore": 0.46,
    "scoreGate": "topScore >= minimumContextScore"
  },
  "errorEnvelopeFields": [
    "error.code",
    "error.message",
    "error.details",
    "error.requestId"
  ],
  "errorCodes": {
    "VALIDATION_ERROR": 422,
    "UNSUPPORTED_FILE_TYPE": 415,
    "FILE_TOO_LARGE": 413,
    "INVALID_FILE_CONTENT": 422,
    "DUPLICATE_DOCUMENT": 409,
    "DOCUMENT_NOT_FOUND": 404,
    "DOCUMENT_NOT_READY": 409,
    "DOCUMENT_STATE_CONFLICT": 409,
    "JOB_NOT_FOUND": 404,
    "QUERY_NOT_FOUND": 404,
    "EVALUATION_RUN_NOT_FOUND": 404,
    "EVALUATION_DATASET_MISSING": 503,
    "EVALUATION_MODE_UNAVAILABLE": 503,
    "INDEX_NOT_READY": 503,
    "INDEX_INCONSISTENT": 503,
    "WORKER_NOT_READY": 503,
    "GENERATION_PROVIDER_UNAVAILABLE": 503,
    "GENERATION_TIMEOUT": 504,
    "GENERATION_PROVIDER_ERROR": 503,
    "GENERATION_RESPONSE_INVALID": 502,
    "INTERNAL_ERROR": 500
  },
  "schemas": {
    "LivenessResponse": ["status", "requestId"],
    "ReadinessResponse": [
      "status",
      "retrievalReady",
      "generationReady",
      "checks.database.ready",
      "checks.index.ready",
      "checks.embedding.ready",
      "checks.worker.ready",
      "checks.generation.ready",
      "requestId"
    ],
    "SystemInfoResponse": [
      "corpus.documentCount",
      "corpus.pageCount",
      "corpus.chunkCount",
      "index.status",
      "index.type",
      "index.version",
      "index.vectorCount",
      "index.dimension",
      "embedding.model",
      "embedding.revision",
      "embedding.dimension",
      "embedding.maxInputTokens",
      "chunking.version",
      "chunking.targetTokens",
      "chunking.maxTokens",
      "chunking.overlapTokens",
      "retrieval.defaultTopK",
      "retrieval.maximumTopK",
      "retrieval.minimumContextScore",
      "retrieval.duplicateSimilarityThreshold",
      "retrieval.rerankerEnabled",
      "generation.enabled",
      "generation.ready",
      "generation.provider",
      "generation.model",
      "generation.timeoutSeconds",
      "generation.maximumConcurrentRequests",
      "capabilities.ocr",
      "capabilities.supportedFileTypes",
      "capabilities.maximumUploadBytes"
    ],
    "DocumentSummary": [
      "id",
      "name",
      "fileType",
      "mimeType",
      "domain",
      "pageCount",
      "chunkCount",
      "createdAt",
      "indexedAt",
      "status",
      "sizeBytes",
      "author",
      "description",
      "sourceUrl",
      "licenseNote"
    ],
    "DocumentDetailResponse": [
      "id",
      "name",
      "fileType",
      "mimeType",
      "domain",
      "title",
      "author",
      "description",
      "sourceUrl",
      "licenseNote",
      "sourceKind",
      "relativeSourcePath",
      "sizeBytes",
      "pageCount",
      "chunkCount",
      "status",
      "failure",
      "activeJobId",
      "createdAt",
      "updatedAt",
      "indexedAt",
      "indexVersion",
      "embedding.model",
      "embedding.revision",
      "embedding.dimension"
    ],
    "DocumentStatsResponse": [
      "totalDocuments",
      "totalPages",
      "totalChunks",
      "indexedDocuments",
      "processingDocuments",
      "failedDocuments",
      "deletingDocuments",
      "domainCounts",
      "fileTypeCounts",
      "indexHealth.status",
      "indexHealth.vectorCount"
    ],
    "DocumentPage": [
      "id",
      "documentId",
      "pageNumber",
      "text",
      "textKind",
      "characterCount",
      "isEmpty",
      "repeatedLinesRemoved"
    ],
    "DocumentChunk": [
      "id",
      "documentId",
      "documentName",
      "chunkIndex",
      "pageNumber",
      "text",
      "tokenCount",
      "status",
      "embeddingDimension"
    ],
    "AcceptedJobResponse": ["jobId", "documentId", "status", "statusUrl"],
    "IngestionJobResponse": [
      "id",
      "documentId",
      "kind",
      "status",
      "stage",
      "progressPercent",
      "stageMessage",
      "attempt",
      "maxAttempts",
      "result",
      "error",
      "createdAt",
      "startedAt",
      "heartbeatAt",
      "updatedAt",
      "completedAt"
    ],
    "ChatQueryRequest": ["question", "topK", "domain"],
    "ChatQueryResponse": [
      "queryId",
      "question",
      "answer",
      "insufficientContext",
      "insufficientReason",
      "citations",
      "sources",
      "timing.retrievalMs",
      "timing.generationMs",
      "timing.totalMs",
      "config.topK",
      "config.minimumContextScore",
      "config.indexVersion"
    ],
    "ChatCitation": [
      "label",
      "documentId",
      "documentName",
      "pageNumber",
      "chunkIndex"
    ],
    "ChatSource": [
      "label",
      "chunkId",
      "documentId",
      "documentName",
      "domain",
      "pageNumber",
      "chunkIndex",
      "text",
      "tokenCount",
      "similarityScore",
      "rank"
    ],
    "RetrievalDetailResponse": [
      "queryId",
      "question",
      "status",
      "insufficientContext",
      "sources",
      "timing.retrievalMs",
      "config.topK",
      "config.domain",
      "config.minimumContextScore",
      "config.indexVersion",
      "createdAt"
    ],
    "Suggestion": ["id", "question", "domain"],
    "EvaluationRunRequest": ["mode", "maximumQuestions"],
    "EvaluationRunAcceptedResponse": ["runId", "jobId", "status", "statusUrl"],
    "EvaluationRunSummary": [
      "id",
      "mode",
      "status",
      "progressPercent",
      "datasetVersion",
      "datasetHash",
      "indexVersion",
      "evaluatedQuestions",
      "totalQuestions",
      "createdAt",
      "startedAt",
      "completedAt",
      "metrics.recallAt1",
      "metrics.recallAt3",
      "metrics.recallAt5",
      "metrics.recallAt10",
      "metrics.mrr",
      "metrics.meanRetrievalLatencyMs",
      "metrics.fallbackAccuracy",
      "metrics.citationRate",
      "metrics.answerCorrectness",
      "metrics.groundedness"
    ],
    "EvaluationDomainMetric": [
      "domain",
      "questionCount",
      "recallAt1",
      "recallAt3",
      "recallAt5",
      "recallAt10",
      "mrr",
      "meanRetrievalLatencyMs",
      "fallbackAccuracy",
      "citationRate",
      "answerCorrectness",
      "groundedness"
    ],
    "EvaluationFailure": [
      "id",
      "evaluationId",
      "question",
      "domain",
      "category",
      "expectedDocumentName",
      "expectedPageNumber",
      "retrievedDocumentName",
      "retrievedPageNumber",
      "firstRelevantRank",
      "topScore",
      "summary"
    ],
    "EvaluationLatestResponse": ["run", "domains", "failures"]
  },
  "operations": {
    "getLiveness": {"method": "GET", "path": "/health/live", "successStatus": 200, "responseSchema": "LivenessResponse", "errors": []},
    "getReadiness": {"method": "GET", "path": "/health/ready", "successStatus": 200, "responseSchema": "ReadinessResponse", "errors": ["INDEX_NOT_READY", "INDEX_INCONSISTENT", "WORKER_NOT_READY"]},
    "getSystemInfo": {"method": "GET", "path": "/api/v1/system/info", "successStatus": 200, "responseSchema": "SystemInfoResponse", "errors": []},
    "listDocuments": {"method": "GET", "path": "/api/v1/documents", "successStatus": 200, "responseSchema": "DocumentSummary", "paginated": true, "errors": ["VALIDATION_ERROR"]},
    "getDocumentStats": {"method": "GET", "path": "/api/v1/documents/stats", "successStatus": 200, "responseSchema": "DocumentStatsResponse", "errors": []},
    "getDocument": {"method": "GET", "path": "/api/v1/documents/{documentId}", "successStatus": 200, "responseSchema": "DocumentDetailResponse", "errors": ["DOCUMENT_NOT_FOUND"]},
    "listDocumentPages": {"method": "GET", "path": "/api/v1/documents/{documentId}/pages", "successStatus": 200, "responseSchema": "DocumentPage", "paginated": true, "errors": ["DOCUMENT_NOT_FOUND", "VALIDATION_ERROR"]},
    "listDocumentChunks": {"method": "GET", "path": "/api/v1/documents/{documentId}/chunks", "successStatus": 200, "responseSchema": "DocumentChunk", "paginated": true, "errors": ["DOCUMENT_NOT_FOUND", "VALIDATION_ERROR"]},
    "uploadDocument": {"method": "POST", "path": "/api/v1/documents/upload", "successStatus": 202, "responseSchema": "AcceptedJobResponse", "errors": ["VALIDATION_ERROR", "UNSUPPORTED_FILE_TYPE", "FILE_TOO_LARGE", "INVALID_FILE_CONTENT", "DUPLICATE_DOCUMENT", "WORKER_NOT_READY"]},
    "deleteDocument": {"method": "DELETE", "path": "/api/v1/documents/{documentId}", "successStatus": 202, "responseSchema": "AcceptedJobResponse", "errors": ["DOCUMENT_NOT_FOUND", "DOCUMENT_STATE_CONFLICT", "INDEX_NOT_READY", "WORKER_NOT_READY"]},
    "getIngestionJob": {"method": "GET", "path": "/api/v1/ingestion-jobs/{jobId}", "successStatus": 200, "responseSchema": "IngestionJobResponse", "errors": ["JOB_NOT_FOUND"]},
    "createChatQuery": {"method": "POST", "path": "/api/v1/chat/queries", "successStatus": 200, "requestSchema": "ChatQueryRequest", "responseSchema": "ChatQueryResponse", "errors": ["VALIDATION_ERROR", "INDEX_NOT_READY", "INDEX_INCONSISTENT", "GENERATION_PROVIDER_UNAVAILABLE", "GENERATION_TIMEOUT", "GENERATION_PROVIDER_ERROR", "GENERATION_RESPONSE_INVALID"]},
    "getRetrievalDetail": {"method": "GET", "path": "/api/v1/retrieval/{queryId}", "successStatus": 200, "responseSchema": "RetrievalDetailResponse", "errors": ["QUERY_NOT_FOUND"]},
    "listChatSuggestions": {"method": "GET", "path": "/api/v1/chat/suggestions", "successStatus": 200, "responseSchema": "Suggestion", "paginated": false, "errors": ["EVALUATION_DATASET_MISSING", "VALIDATION_ERROR"]},
    "createEvaluationRun": {"method": "POST", "path": "/api/v1/evaluation/runs", "successStatus": 202, "requestSchema": "EvaluationRunRequest", "responseSchema": "EvaluationRunAcceptedResponse", "errors": ["VALIDATION_ERROR", "EVALUATION_DATASET_MISSING", "EVALUATION_MODE_UNAVAILABLE", "INDEX_NOT_READY", "WORKER_NOT_READY"]},
    "listEvaluationRuns": {"method": "GET", "path": "/api/v1/evaluation/runs", "successStatus": 200, "responseSchema": "EvaluationRunSummary", "paginated": true, "errors": ["VALIDATION_ERROR"]},
    "getEvaluationRun": {"method": "GET", "path": "/api/v1/evaluation/runs/{runId}", "successStatus": 200, "responseSchema": "EvaluationRunSummary", "errors": ["EVALUATION_RUN_NOT_FOUND"]},
    "listEvaluationDomains": {"method": "GET", "path": "/api/v1/evaluation/runs/{runId}/domains", "successStatus": 200, "responseSchema": "EvaluationDomainMetric", "errors": ["EVALUATION_RUN_NOT_FOUND"]},
    "listEvaluationFailures": {"method": "GET", "path": "/api/v1/evaluation/runs/{runId}/failures", "successStatus": 200, "responseSchema": "EvaluationFailure", "paginated": true, "errors": ["EVALUATION_RUN_NOT_FOUND", "VALIDATION_ERROR"]},
    "getLatestEvaluation": {"method": "GET", "path": "/api/v1/evaluation/latest", "successStatus": 200, "responseSchema": "EvaluationLatestResponse", "errors": ["EVALUATION_DATASET_MISSING"]}
  },
  "frontendCoverage": {
    "frontend/src/App.tsx": ["getSystemInfo", "listDocuments", "deleteDocument", "getIngestionJob"],
    "frontend/src/components/DashboardChat.tsx": ["getSystemInfo", "listDocuments", "createChatQuery", "getRetrievalDetail", "listChatSuggestions"],
    "frontend/src/components/DocumentLibrary.tsx": ["listDocuments", "getDocumentStats", "deleteDocument", "getIngestionJob"],
    "frontend/src/components/UploadDocuments.tsx": ["getSystemInfo", "uploadDocument", "getIngestionJob"],
    "frontend/src/components/DocumentDetail.tsx": ["getDocument", "listDocumentPages", "listDocumentChunks"],
    "frontend/src/components/Evaluation.tsx": ["createEvaluationRun", "listEvaluationRuns", "getEvaluationRun", "listEvaluationDomains", "listEvaluationFailures", "getLatestEvaluation"]
  },
  "mockReplacementCoverage": {
    "INITIAL_DOCUMENTS": ["listDocuments", "getDocumentStats"],
    "localAddDeleteState": ["uploadDocument", "deleteDocument", "getIngestionJob", "listDocuments"],
    "MOCK_CHUNKS": ["listDocumentChunks"],
    "simulatedPagePreview": ["listDocumentPages"],
    "PRESET_QASAnswers": ["createChatQuery"],
    "PRESET_QASEvidence": ["createChatQuery", "getRetrievalDetail"],
    "presetQuestionButtons": ["listChatSuggestions"],
    "timedFakeIngestion": ["uploadDocument", "getIngestionJob"],
    "fakeUploadedMetadata": ["getDocument"],
    "INITIAL_METRICS": ["getLatestEvaluation"],
    "DOMAIN_PERFORMANCE": ["listEvaluationDomains", "getLatestEvaluation"],
    "FAILURE_ANALYSIS_DATA": ["listEvaluationFailures", "getLatestEvaluation"]
  }
}
